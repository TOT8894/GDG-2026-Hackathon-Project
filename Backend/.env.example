PORT=5000
MONGO_URI=your_mongodb_connection_string
ACCESS_TOKEN_SECRET_KEY=your_super_secret_access_key
REFRESH_TOKEN_SECRET_KEY=your_super_secret_refresh_key
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CLIENT_URL=http://localhost:6006

# Kafka Configuration (Defaults work for local Docker setup)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kuralew-backend

# Email Configuration (Used by the Kafka Consumer)
# Important: If using Gmail, you MUST use an "App Password", NOT your normal account password!
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_team_email@gmail.com
EMAIL_PASS=your_16_digit_app_password
